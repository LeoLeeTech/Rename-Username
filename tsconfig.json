{
  "extends": "./.wxt/tsconfig.json",
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints/**/*.ts",
    "entrypoints/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "wxt.config.ts"
  ],
  "exclude": [
    "node_modules/**",
    "build/**",
    ".output/**"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strictFunctionTypes": false,
    "noImplicitThis": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "paths": {
      "~*": [
        "./src/*"
      ]
    },
    "strictNullChecks": true
  }
}
