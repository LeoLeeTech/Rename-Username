{
  "name": "utags",
  "displayName": "UTags - Add usertags to links",
  "displayName:zh-CN": "小鱼标签 (UTags) - 为链接添加用户标签",
  "version": "0.34.2",
  "description": "Browser extension for custom user labels on websites.",
  "type": "module",
  "author": "Pipecraft",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/utags/utags/issues"
  },
  "homepage": "https://github.com/utags/utags#readme",
  "scripts": {
    "format": "prettier --write . && npx prettier@2.8.8 --config .prettierrc-markdown.cjs --write '**/*.md'",
    "xo": "xo",
    "lint": "run-s lint:*",
    "lint:format": "npm run format",
    "lint:code": "xo --fix",
    "lint:type": "tsc --noemit",
    "dev": "run-p dev:*",
    "dev:chrome": "plasmo dev",
    "dev:firefox": "sleep 2 && plasmo dev --target=firefox-mv2",
    "dev:firefox-mv3": "sleep 2 && plasmo dev --target=firefox-mv3",
    "build": "run-s build:*",
    "build:chrome": "cross-env PARCEL_WORKER_BACKEND=process plasmo build && node scripts/chrome/update-manifest.mjs && node scripts/wrap-shadow-root.mjs build/chrome-mv3-prod",
    "build:firefox": "cross-env PARCEL_WORKER_BACKEND=process plasmo build --target=firefox-mv2 && node scripts/firefox/update-manifest.mjs && node scripts/wrap-shadow-root.mjs build/firefox-mv2-prod && addons-linter build/firefox-mv2-prod/",
    "build:firefox-mv3": "cross-env PARCEL_WORKER_BACKEND=process plasmo build --target=firefox-mv3 && node scripts/firefox/update-manifest.mjs && node scripts/wrap-shadow-root.mjs build/firefox-mv3-prod && addons-linter build/firefox-mv3-prod/",
    "package": "run-s package:*",
    "package:chrome": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv2 && addons-linter build/firefox-mv2-prod.zip",
    "package:firefox-mv3": "plasmo package --target=firefox-mv3 && addons-linter build/firefox-mv3-prod.zip",
    "test": "vitest --run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "browser-extension-i18n": "^0.1.3",
    "browser-extension-settings": "^0.9.0",
    "browser-extension-storage": "^0.2.10",
    "browser-extension-utils": "^0.5.2",
    "focus-trap-lite": "^0.1.0",
    "plasmo": "^0.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "utags-utils": "^0.3.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@types/chrome": "^0.1.32",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "addons-linter": "^10.3.0",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.4",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "xo": "^1.2.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "{a0b2a0f8-83a5-449a-8e47-3b257da0bb37}",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}
