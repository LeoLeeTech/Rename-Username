{
  "name": "rename",
  "displayName": "Rename",
  "displayName:zh-CN": "Rename",
  "version": "0.0.1",
  "description": "Rename text on websites and keep custom names locally in your browser.",
  "type": "module",
  "author": "LeoLeeTech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeoLeeTech/Rename.git"
  },
  "bugs": {
    "url": "https://github.com/LeoLeeTech/Rename/issues"
  },
  "homepage": "https://github.com/LeoLeeTech/Rename#readme",
  "scripts": {
    "format": "prettier --write .",
    "typecheck": "tsc --noemit",
    "dev": "plasmo dev",
    "build": "PARCEL_WORKER_BACKEND=process plasmo build && node scripts/chrome/update-manifest.mjs && node scripts/wrap-shadow-root.mjs build/chrome-mv3-prod",
    "package": "plasmo package"
  },
  "dependencies": {
    "browser-extension-i18n": "^0.1.3",
    "browser-extension-settings": "^0.9.0",
    "browser-extension-storage": "^0.2.10",
    "browser-extension-utils": "^0.5.2",
    "focus-trap-lite": "^0.1.0",
    "plasmo": "^0.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "utags-utils": "^0.3.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@types/chrome": "^0.1.32",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.7.4",
    "sass": "^1.99.0",
    "typescript": "^5.9.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ]
  }
}
